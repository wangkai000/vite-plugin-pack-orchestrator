{
  "name": "vite-plugin-pack-orchestrator",
  "version": "1.0.0",
  "description": "Vite plugin for auto-archiving dist folder to ZIP/TAR/7Z after build",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "keywords": [
    "vite",
    "plugin",
    "archive",
    "zip",
    "tar",
    "tar.gz",
    "7z",
    "pack"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "vite": "^4.0.0 || ^5.0.0 || ^6.0.0"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "execa": "^9.5.0",
    "picomatch": "^4.0.2",
    "tar": "^7.4.3"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/node": "^20.14.0",
    "@types/picomatch": "^3.0.0",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  }
}
